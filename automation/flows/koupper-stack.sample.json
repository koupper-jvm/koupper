        "inputs": {},
        "wait": true,
        "timeoutSeconds": 1800,
        "pollIntervalSeconds": 20
      },
      "issues": [
        {
          "title": "refactor(provider): github provider backlog",
          "body": "Track follow-up refactors for GitHub provider hardening.",
          "labels": [
            "refactor",
            "provider"
          ],
          "assignees": []
        }
      ]
    },
    {
