{
  "dryRun": true,
  "continueOnError": false,
  "targets": [
    {
      "name": "koupper-core-pre-merge-smoke",
      "enabled": true,
      "owner": "koupper-jvm",
      "repo": "koupper",
      "pullRequest": {
        "create": false,
        "head": "feature/my-branch",
        "base": "develop",
        "number": null,
        "merge": false,
        "mergeMethod": "merge"
      },
      "checks": {
        "wait": true,
        "ref": "refs/heads/feature/my-branch",
        "required": [
          "PR Fast Checks"
        ],
        "timeoutSeconds": 900,
        "pollIntervalSeconds": 15
      },
      "workflow": {
        "dispatch": true,
        "workflowId": "full-smoke-suite.yml",
        "ref": "feature/my-branch",
        "inputs": {},
        "wait": true,
        "timeoutSeconds": 2400,
        "pollIntervalSeconds": 20
      },
      "issues": []
    }
  ]
}
