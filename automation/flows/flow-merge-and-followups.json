{
  "dryRun": true,
  "continueOnError": false,
  "targets": [
    {
      "name": "koupper-core-merge-followups",
      "enabled": true,
      "owner": "koupper-jvm",
      "repo": "koupper",
      "pullRequest": {
        "create": false,
        "head": "feature/my-branch",
        "base": "develop",
        "number": 0,
        "merge": true,
        "mergeMethod": "merge"
      },
      "checks": {
        "wait": false,
        "ref": "",
        "required": [],
        "timeoutSeconds": 900,
        "pollIntervalSeconds": 15
      },
      "workflow": {
        "dispatch": false,
        "workflowId": "",
        "ref": "develop",
        "inputs": {},
        "wait": false,
        "timeoutSeconds": 1800,
        "pollIntervalSeconds": 20
      },
      "issues": [],
      "issueTemplatePack": {
        "enabled": true,
        "kind": "provider-refactor",
        "providers": [
          "db",
          "github",
          "ai"
        ],
        "labels": [
          "refactor",
          "provider"
        ],
        "assignees": [],
        "bodyPrefix": "Generated automatically from automation flow after PR merge."
      }
    }
  ]
}
