{
  "version": "1.0",
  "providers": [
    {
      "id": "db",
      "serviceProvider": "DBServiceProvider",
      "description": "Database connectors for PostgreSQL and SQLite sessions.",
      "bindings": [
        {
          "contract": "DBConnector",
          "implementations": [
            { "class": "DBPSQLConnector", "tag": "DBPSQLConnector" },
            { "class": "DBSQLiteConnector", "tag": "DBSQLiteConnector" }
          ]
        }
      ],
      "env": [
        { "name": "DB_HOST", "required": false, "description": "PostgreSQL host." },
        { "name": "DB_PORT", "required": false, "description": "PostgreSQL port." },
        { "name": "DB_DATABASE", "required": true, "description": "Database name/path." },
        { "name": "DB_USERNAME", "required": false, "description": "PostgreSQL user." },
        { "name": "DB_PASSWORD", "required": false, "description": "PostgreSQL password." }
      ],
      "docs": "https://koupper.com/docs/providers/db"
    },
    {
      "id": "mailing",
      "serviceProvider": "SenderServiceProvider",
      "description": "SMTP email sender utilities.",
      "bindings": [
        {
          "contract": "Sender",
          "implementations": [
            { "class": "SenderHtmlEmail" }
          ]
        }
      ],
      "env": [
        { "name": "MAIL_HOST", "required": true, "description": "SMTP host." },
        { "name": "MAIL_PORT", "required": true, "description": "SMTP port." },
        { "name": "MAIL_USERNAME", "required": true, "description": "SMTP username/from email." },
        { "name": "MAIL_PASSWORD", "required": true, "description": "SMTP password." },
        { "name": "EMAIL_FROM_NAME", "required": false, "description": "Display sender name." },
        { "name": "DEFAULT_TARGET_EMAIL", "required": false, "description": "Default recipient." },
        { "name": "DEFAULT_SUBJECT", "required": false, "description": "Default email subject." }
      ],
      "docs": "https://koupper.com/docs/providers/mailing"
    },
    {
      "id": "docker",
      "serviceProvider": "DockerServiceProvider",
      "description": "Docker CLI automation provider for image, container and compose workflows.",
      "bindings": [
        {
          "contract": "DockerClient",
          "implementations": [
            { "class": "DockerCliClient" }
          ]
        }
      ],
      "env": [
        { "name": "DOCKER_COMMAND", "required": false, "description": "Docker command binary (default: docker)." },
        { "name": "DOCKER_HOST", "required": false, "description": "Docker host endpoint override." },
        { "name": "DOCKER_CONTEXT", "required": false, "description": "Docker context name override." },
        { "name": "DOCKER_TIMEOUT_SECONDS", "required": false, "description": "Command timeout in seconds." },
        { "name": "DOCKER_WORKDIR", "required": false, "description": "Working directory for docker commands." }
      ],
      "docs": "https://koupper.com/docs/providers/docker"
    },
    {
      "id": "logger",
      "serviceProvider": "LoggerServiceProvider",
      "description": "Database-backed application logger.",
      "bindings": [
        {
          "contract": "Logger",
          "implementations": [
            { "class": "PSQLDBLogger" }
          ]
        }
      ],
      "env": [
        { "name": "LOGGER_TABLE_NAME", "required": true, "description": "Target table for log persistence." }
      ],
      "docs": "https://koupper.com/docs/providers/logger"
    },
    {
      "id": "mcp",
      "serviceProvider": "MCPServiceProvider",
      "description": "MCP-style local tool server provider with HTTP tool discovery and invocation endpoints.",
      "bindings": [
        {
          "contract": "MCPServerProvider",
          "implementations": [
            { "class": "LocalMCPServerProvider" }
          ]
        }
      ],
      "env": [],
      "docs": "https://koupper.com/docs/providers/mcp"
    },
    {
      "id": "n8n",
      "serviceProvider": "N8NServiceProvider",
      "description": "n8n workflow trigger and execution polling provider.",
      "bindings": [
        {
          "contract": "N8NProvider",
          "implementations": [
            { "class": "N8NHttpProvider" }
          ]
        }
      ],
      "env": [
        { "name": "N8N_MODE", "required": false, "description": "mock (default) or live" },
        { "name": "N8N_WEBHOOK_URL", "required": false, "description": "Default webhook URL for triggerWorkflow in live mode." },
        { "name": "N8N_API_BASE_URL", "required": false, "description": "n8n API base URL used for execution status queries." },
        { "name": "N8N_API_KEY", "required": false, "description": "n8n API key for execution status queries." },
        { "name": "N8N_TIMEOUT_SECONDS", "required": false, "description": "HTTP timeout for n8n requests." }
      ],
      "docs": "https://koupper.com/docs/providers/n8n"
    },
    {
      "id": "notifications",
      "serviceProvider": "NotificationsServiceProvider",
      "description": "Operational notifications provider for console or webhook destinations.",
      "bindings": [
        {
          "contract": "NotificationsProvider",
          "implementations": [
            { "class": "ConsoleNotificationsProvider" },
            { "class": "WebhookNotificationsProvider" }
          ]
        }
      ],
      "env": [
        { "name": "NOTIFICATIONS_PROVIDER", "required": false, "description": "console (default), webhook, slack, discord, teams" },
        { "name": "NOTIFICATIONS_WEBHOOK_URL", "required": false, "description": "Webhook URL for webhook-based notification providers." }
      ],
      "docs": "https://koupper.com/docs/providers/notifications"
    },
    {
      "id": "observability",
      "serviceProvider": "ObservabilityServiceProvider",
      "description": "Metrics, events and traces sink provider with local JSONL backend.",
      "bindings": [
        {
          "contract": "ObservabilityProvider",
          "implementations": [
            { "class": "LocalObservabilityProvider" }
          ]
        }
      ],
      "env": [
        { "name": "OBSERVABILITY_SINK_FILE", "required": false, "description": "JSONL output sink path for emitted telemetry." }
      ],
      "docs": "https://koupper.com/docs/providers/observability"
    },
    {
      "id": "queue-ops",
      "serviceProvider": "QueueOpsServiceProvider",
      "description": "Queue operations provider with local pending/requeue/dead-letter management.",
      "bindings": [
        {
          "contract": "QueueOpsProvider",
          "implementations": [
            { "class": "LocalQueueOpsProvider" }
          ]
        }
      ],
      "env": [
        { "name": "QUEUE_OPS_STORE_FILE", "required": false, "description": "JSON store path for local queue operations backend." }
      ],
      "docs": "https://koupper.com/docs/providers/queue-ops"
    },
    {
      "id": "http",
      "serviceProvider": "HttpServiceProvider",
      "description": "HTTP invoker for outbound API requests.",
      "bindings": [
        {
          "contract": "HtppClient",
          "implementations": [
            { "class": "HttpInvoker" }
          ]
        }
      ],
      "env": [],
      "docs": "https://koupper.com/docs/providers/http"
    },
    {
      "id": "command-runner",
      "serviceProvider": "CommandRunnerServiceProvider",
      "description": "Generic command execution provider for shell and binary commands with timeout and dry-run support.",
      "bindings": [
        {
          "contract": "CommandRunner",
          "implementations": [
            { "class": "DefaultCommandRunner" }
          ]
        }
      ],
      "env": [
        { "name": "COMMAND_RUNNER_TIMEOUT_SECONDS", "required": false, "description": "Default timeout in seconds for command execution." },
        { "name": "COMMAND_RUNNER_SHELL_WINDOWS", "required": false, "description": "Shell command used on Windows for shellCommand mode (default: pwsh)." },
        { "name": "COMMAND_RUNNER_SHELL_UNIX", "required": false, "description": "Shell command used on Unix for shellCommand mode (default: bash)." }
      ],
      "docs": "https://koupper.com/docs/providers/command-runner"
    },
    {
      "id": "iac",
      "serviceProvider": "IaCServiceProvider",
      "description": "Terraform-based IaC operations provider with approval guard for apply.",
      "bindings": [
        {
          "contract": "IaCProvider",
          "implementations": [
            { "class": "TerraformIaCProvider" }
          ]
        }
      ],
      "env": [
        { "name": "TERRAFORM_COMMAND", "required": false, "description": "Terraform binary command." },
        { "name": "TERRAFORM_TIMEOUT_SECONDS", "required": false, "description": "Terraform command timeout in seconds." }
      ],
      "docs": "https://koupper.com/docs/providers/iac"
    },
    {
      "id": "process-supervisor",
      "serviceProvider": "ProcessSupervisorServiceProvider",
      "description": "Local long-running process supervisor for detached dev servers with persisted metadata and log access.",
      "bindings": [
        {
          "contract": "ProcessSupervisor",
          "implementations": [
            { "class": "LocalProcessSupervisor" }
          ]
        },
        {
          "contract": "ProcessOrchestrator",
          "implementations": [
            { "class": "LocalProcessSupervisor" }
          ]
        }
      ],
      "env": [
        { "name": "PROCESS_SUPERVISOR_STORE_PATH", "required": false, "description": "Path to process metadata store file (default: ~/.koupper/processes.json)." },
        { "name": "PROCESS_SUPERVISOR_LOG_DIR", "required": false, "description": "Directory for process log files (default: ~/.koupper/process-logs)." },
        { "name": "PROCESS_SUPERVISOR_SHELL_WINDOWS", "required": false, "description": "Shell binary for shellCommand mode on Windows (default: pwsh)." },
        { "name": "PROCESS_SUPERVISOR_SHELL_UNIX", "required": false, "description": "Shell binary for shellCommand mode on Unix (default: bash)." }
      ],
      "docs": "https://koupper.com/docs/providers/process-supervisor"
    },
    {
      "id": "job-ops",
      "serviceProvider": "JobOpsServiceProvider",
      "description": "Typed job orchestration operations for status/list/run/failed/retry without shelling to CLI.",
      "bindings": [
        {
          "contract": "JobOps",
          "implementations": [
            { "class": "DefaultJobOps" }
          ]
        }
      ],
      "env": [],
      "docs": "https://koupper.com/docs/providers/job-ops"
    },
    {
      "id": "local-e2e",
      "serviceProvider": "LocalE2EServiceProvider",
