            { "class": "KubectlK8sProvider" }
          ]
        }
      ],
      "env": [
        { "name": "KUBECTL_COMMAND", "required": false, "description": "kubectl binary command." },
        { "name": "KUBECTL_TIMEOUT_SECONDS", "required": false, "description": "Command timeout in seconds." }
      ],
      "docs": "https://koupper.com/docs/providers/k8s"
    },
    {
      "id": "crypto",
      "serviceProvider": "CryptoServiceProvider",
      "description": "Symmetric encryption helpers.",
      "bindings": [
        {
          "contract": "Crypt0",
          "implementations": [
            { "class": "AESGCM128" }
          ]
        }
      ],
      "env": [
        { "name": "SHARED_SECRET", "required": true, "description": "Encryption shared secret." }
      ],
      "docs": "https://koupper.com/docs/providers/crypto"
    },
    {
      "id": "aws-dynamo",
      "serviceProvider": "AwsServiceProvider",
      "description": "DynamoDB data access provider.",
      "bindings": [
        {
          "contract": "DynamoClient",
          "implementations": [
            { "class": "DynamoClientImpl" }
          ]
        },
        {
          "contract": "DynamoLocalAdmin",
          "implementations": [
            { "class": "DynamoLocalAdminImpl" }
          ]
        }
      ],
      "env": [
        { "name": "DYNAMO_REGION", "required": true, "description": "DynamoDB region." },
        { "name": "DYNAMO_URL", "required": false, "description": "Local/custom endpoint URL." },
        { "name": "AWS_ACCESS_KEY_ID", "required": false, "description": "AWS access key (optional for local)." },
        { "name": "AWS_SECRET_ACCESS_KEY", "required": false, "description": "AWS secret key (optional for local)." },
        { "name": "AWS_SESSION_TOKEN", "required": false, "description": "AWS session token." }
      ],
      "docs": "https://koupper.com/docs/providers/aws-dynamo"
    },
    {
      "id": "aws-s3",
      "serviceProvider": "AwsS3ServiceProvider",
      "description": "S3 storage provider for uploads and presigned flows.",
      "bindings": [
        {
          "contract": "S3Client",
          "implementations": [
            { "class": "S3ClientImpl" }
          ]
        }
      ],
      "env": [
        { "name": "QUIZZTEA_S3_BUCKET", "required": true, "description": "S3 bucket name." },
        { "name": "AWS_REGION", "required": true, "description": "AWS region for S3." },
        { "name": "S3_URL", "required": false, "description": "Local/custom S3 endpoint URL." },
        { "name": "AWS_ACCESS_KEY_ID", "required": false, "description": "AWS access key (optional for local)." },
        { "name": "AWS_SECRET_ACCESS_KEY", "required": false, "description": "AWS secret key (optional for local)." },
        { "name": "AWS_SESSION_TOKEN", "required": false, "description": "AWS session token." }
      ],
      "docs": "https://koupper.com/docs/providers/aws-s3"
    },
    {
      "id": "aws-deploy",
      "serviceProvider": "AwsDeployServiceProvider",
      "description": "AWS deployment orchestration provider for Lambda, static site rollout, preflight checks and API smoke tests.",
      "bindings": [
        {
          "contract": "AwsDeployProvider",
          "implementations": [
            { "class": "AwsCliDeployProvider" }
          ]
        }
      ],
      "env": [
        { "name": "AWS_COMMAND", "required": false, "description": "AWS CLI binary name/path (default: aws)." },
        { "name": "AWS_REGION", "required": false, "description": "Default AWS region (default: us-east-1)." },
        { "name": "AWS_DEPLOY_TIMEOUT_SECONDS", "required": false, "description": "Timeout in seconds for each AWS CLI command (default: 300)." },
        { "name": "AWS_ACCESS_KEY_ID", "required": false, "description": "AWS access key for runtime AWS CLI authentication." },
        { "name": "AWS_SECRET_ACCESS_KEY", "required": false, "description": "AWS secret key for runtime AWS CLI authentication." },
        { "name": "AWS_SESSION_TOKEN", "required": false, "description": "AWS session token for temporary credentials." }
      ],
      "docs": "https://koupper.com/docs/providers/aws-deploy"
    },
