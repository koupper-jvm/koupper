      "bindings": [
        {
          "contract": "LocalE2E",
          "implementations": [
            { "class": "DefaultLocalE2E" }
          ]
        }
      ],
      "env": [],
      "docs": "https://koupper.com/docs/providers/local-e2e"
    },
    {
      "id": "files",
      "serviceProvider": "FileServiceProvider",
      "description": "File, text, JSON and YAML handlers.",
      "bindings": [
        {
          "contract": "FileHandler",
          "implementations": [
            { "class": "FileHandlerImpl" }
          ]
        },
        {
          "contract": "TextFileHandler",
          "implementations": [
            { "class": "TextFileHandlerImpl" }
          ]
        },
        {
          "contract": "JSONFileHandler",
          "implementations": [
            { "class": "JSONFileHandlerImpl" }
          ]
        },
        {
          "contract": "YmlFileHandler",
          "implementations": [
            { "class": "YmlFileHandlerImpl" }
          ]
        }
      ],
      "env": [],
      "docs": "https://koupper.com/docs/providers/files"
    },
    {
      "id": "jwt",
      "serviceProvider": "JWTServiceProvider",
      "description": "JWT signing and validation utilities.",
      "bindings": [
        {
          "contract": "JWT",
          "implementations": [
            { "class": "JWTAgent" }
          ]
        }
      ],
      "env": [
        { "name": "JWT_SECRET", "required": true, "description": "JWT shared secret key." }
      ],
      "docs": "https://koupper.com/docs/providers/jwt"
    },
    {
      "id": "k8s",
      "serviceProvider": "K8sServiceProvider",
      "description": "Kubernetes operations provider over kubectl for apply/get/logs/rollout workflows.",
      "bindings": [
